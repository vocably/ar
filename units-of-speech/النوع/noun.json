{"transcript":"al-nawʿ","exists":true,"definitions":["صنف أو فئة من الكائنات أو الأشياء التي تشترك في خصائص معينة.","طريقة أو أسلوب معين.","جنس أو فصيلة."],"examples":["هذا النوع من الفاكهة لذيذ.","تفضل أي نوع من الموسيقى؟","تتعدد أنواع الحيوانات في الغابة."],"lemma":"نوع","lemmaPos":"verb","synonyms":["الصنف","الفئة","الجنس","الشكل"],"number":"singular","pluralForm":"الأنواع","gender":"masculine","source":"النوع"}